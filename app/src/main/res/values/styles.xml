<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 
        Custom Dialog Theme for Puter Unofficial.
        Ensures that all native popups (like Help or Custom Instructions) 
        follow the clean white theme and do not use dark mode colors.
    -->
    <style name="Theme.Puter.Dialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorPrimary">@color/puter_blue</item>
        <item name="colorAccent">@color/puter_accent</item>
        <item name="android:textColorPrimary">@color/text_dark</item>
    </style>

    <!-- 
        Button Style for Settings and Native UI.
        Matches the blue branding seen in your original search bar.
    -->
    <style name="PuterPrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/puter_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 
        Style for Input fields inside native dialogs.
    -->
    <style name="PuterEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/edit_text_border</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">16sp</item>
    </style>

</resources>